# Sawla Tours enquiry delivery
# Never commit real secrets. Copy to .env.local for development or configure in hosting.

# Required for production email delivery through Resend
RESEND_API_KEY=re_xxxxxxxxx
ENQUIRY_FROM_EMAIL="Sawla Tours <enquiries@sawlatours.com>"
ENQUIRY_TO_EMAIL=explore@sawlatours.com

# email = deliver through Resend; log = local/staging test without sending email
ENQUIRY_DELIVERY_MODE=email

# Optional CRM / automation webhook. The full validated enquiry is sent as JSON.
ENQUIRY_WEBHOOK_URL=
ENQUIRY_WEBHOOK_SECRET=

# Required in production for distributed rate limiting and encrypted recovery records
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Generate with: openssl rand -base64 32
ENQUIRY_STORAGE_KEY=
ENQUIRY_RETENTION_DAYS=30

# Optional test override; leave unset in production
RESEND_API_URL=

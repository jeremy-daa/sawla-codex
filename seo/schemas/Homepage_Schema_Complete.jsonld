    {
      "@type": "FAQPage",
      "@id": "https://www.sawlatours.com/#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "When is the best time to visit Ethiopia?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The main dry season runs from October to June, with October-February being optimal for most destinations. The Danakil Depression should only be visited November-February. The rainy season (June-September) makes some roads impassable but brings lower prices and fewer crowds."
          }
        },
        {
          "@type": "Question",
          "name": "Do I need a visa to visit Ethiopia?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Most nationalities can apply for an Ethiopian e-Visa online at www.evisa.gov.et. Processing typically takes 3-5 business days. Sawla Tours provides detailed visa guidance as part of every booking."
          }
        },
        {
          "@type": "Question",
          "name": "Is Ethiopia safe for tourists?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The main tourist circuits — Lalibela, Gondar, Axum, Simien Mountains, Addis Ababa — are safe and visited by thousands of international tourists each year. Sawla Tours monitors conditions continuously and only operates in areas with confirmed stable security. All itineraries are designed with safety as the primary constraint."
          }
        },
        {
          "@type": "Question",
          "name": "What vaccinations do I need for Ethiopia?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yellow fever vaccination is required if arriving from a yellow fever endemic country and recommended for all visitors. Hepatitis A and B, typhoid, and routine vaccinations are recommended. Malaria prophylaxis is required for low-altitude areas including the Omo Valley, Gambella, and Danakil. Sawla Tours provides a comprehensive health brief with every booking."
          }
        },
        {
          "@type": "Question",
          "name": "Can I see Ethiopian wolves in the wild?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. The Bale Mountains National Park holds approximately 300 Ethiopian wolves — the world's largest single population. In the Web Valley and Sanetti Plateau, wolf sightings are reliable year-round. Our guides know individual animals by name. The best time is dawn, when wolves are actively hunting giant mole rats."
          }
        },
        {
          "@type": "Question",
          "name": "How far in advance should I book an Ethiopia tour?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "For festival periods (Timkat in January, Meskel in September) and peak season (October-January), we recommend booking 6-9 months in advance as accommodation in Lalibela and the Simien Mountains fills early. For other periods, 2-3 months is usually sufficient. We can sometimes accommodate shorter notice bookings — contact us to discuss."
          }
        }
      ]
    }
  ]
